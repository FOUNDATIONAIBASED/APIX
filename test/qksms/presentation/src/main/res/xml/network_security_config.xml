<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext HTTP/WebSocket for local/homelab ApiX gateways (ws://).
  For production, prefer wss:// and TLS on the server.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
