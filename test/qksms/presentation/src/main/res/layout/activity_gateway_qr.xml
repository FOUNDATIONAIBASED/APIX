<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <include layout="@layout/toolbar" />

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/gatewayBarcodeView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:zxing_scanner_layout="@layout/zxing_capture" />

    <com.moez.QKSMS.common.widget.QkTextView
        android:id="@+id/gatewayQrInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center"
        android:text="@string/gateway_scan_qr_instruction"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.35" />

    <Button
        android:id="@+id/gatewayQrCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="@android:string/cancel" />
</LinearLayout>
