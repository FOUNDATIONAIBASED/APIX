<?xml version="1.0" encoding="utf-8"?>
<!-- App is always dark — night theme is identical to default -->
<resources>
    <style name="Theme.ApiX" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/bg2</item>
        <item name="colorPrimaryVariant">@color/accent_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/bg</item>
        <item name="colorSurface">@color/surface1</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/accent_red</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg2</item>
        <item name="android:navigationBarColor">@color/bg2</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="materialCardViewStyle">@style/Widget.ApiX.Card</item>
        <item name="bottomNavigationStyle">@style/Widget.ApiX.BottomNav</item>
        <item name="toolbarStyle">@style/Widget.ApiX.Toolbar</item>
    </style>
</resources>
