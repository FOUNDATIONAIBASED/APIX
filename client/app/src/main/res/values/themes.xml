<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ApiX" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colour system -->
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/bg2</item>
        <item name="colorPrimaryVariant">@color/accent_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorSecondaryVariant">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/bg</item>
        <item name="colorSurface">@color/surface1</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/accent_red</item>
        <item name="colorOnError">@color/white</item>
        <!-- Window -->
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg2</item>
        <item name="android:navigationBarColor">@color/bg2</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <!-- Widgets -->
        <item name="materialCardViewStyle">@style/Widget.ApiX.Card</item>
        <item name="bottomNavigationStyle">@style/Widget.ApiX.BottomNav</item>
        <item name="toolbarStyle">@style/Widget.ApiX.Toolbar</item>
        <item name="snackbarStyle">@style/Widget.ApiX.Snackbar</item>
    </style>

    <!-- Shapes -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Card -->
    <style name="Widget.ApiX.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface1</item>
        <item name="strokeColor">@color/border1</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.ApiX.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg2</item>
        <item name="itemTextColor">@drawable/bnv_text_color</item>
        <item name="itemIconTint">@drawable/bnv_text_color</item>
        <item name="itemRippleColor">@color/accent_blue</item>
        <item name="android:minHeight">64dp</item>
    </style>

    <!-- Toolbar -->
    <style name="Widget.ApiX.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg2</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- Snackbar -->
    <style name="Widget.ApiX.Snackbar" parent="Widget.MaterialComponents.Snackbar">
        <item name="android:background">@color/surface2</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.ApiX.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/accent_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="Widget.ApiX.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border2</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Text styles -->
    <style name="TextStyle.ApiX.Label" parent="">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">9sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="TextStyle.ApiX.Value" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="TextStyle.ApiX.Mono" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Discover activity -->
    <style name="Theme.ApiX.Discover" parent="Theme.ApiX">
        <item name="android:windowBackground">@color/bg</item>
    </style>

</resources>
