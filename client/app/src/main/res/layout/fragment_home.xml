<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Connection Status Card -->
        <LinearLayout
            android:id="@+id/cardConnection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="10dp">

            <!-- Status dot -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/status_dot_red"
                android:layout_marginEnd="12dp" />

            <!-- Server info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_server_label"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvServerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not connected"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvConnectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_status_offline"
                    android:textColor="@color/accent_red"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Pause button -->
            <Button
                android:id="@+id/btnPauseRelay"
                android:layout_width="80dp"
                android:layout_height="34dp"
                android:text="@string/home_pause_relay"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_btn_ghost"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Today's Stats Row -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- Sent -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_stat_card"
                android:layout_marginEnd="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_sent_today"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />
                <TextView
                    android:id="@+id/tvSentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent_blue"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Received -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_stat_card"
                android:layout_marginHorizontal="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_received_today"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />
                <TextView
                    android:id="@+id/tvReceivedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent_green"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Failed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_stat_card"
                android:layout_marginStart="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_failed_today"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />
                <TextView
                    android:id="@+id/tvFailedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent_red"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- SIM Cards -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM CARDS"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/layoutSims"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="10dp" />

        <!-- Device Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICE"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />
                <TextView
                    android:id="@+id/tvDeviceModel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Battery -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATTERY"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />
                <TextView
                    android:id="@+id/tvBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_green"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
