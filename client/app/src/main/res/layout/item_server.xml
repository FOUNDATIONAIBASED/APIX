<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/bg_server_item"
    android:layout_marginBottom="8dp">

    <!-- Server icon -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_chip_blue">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="S"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvServerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ApiX Gateway"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvServerAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="192.168.1.100:3000"
            android:textColor="@color/accent_cyan"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Ping badge -->
    <TextView
        android:id="@+id/tvPing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:text="12ms"
        android:textColor="@color/accent_green"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:background="@drawable/bg_chip_green"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp" />

    <!-- Connect button -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="72dp"
        android:layout_height="32dp"
        android:text="Connect"
        android:textColor="@color/white"
        android:background="@drawable/bg_btn_primary"
        android:textSize="10sp"
        android:fontFamily="monospace" />

</LinearLayout>
