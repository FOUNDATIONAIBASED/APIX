<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="6dp">

    <!-- Direction indicator -->
    <TextView
        android:id="@+id/tvDirection"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="↑"
        android:textColor="@color/accent_blue"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="monospace"
        android:background="@drawable/bg_chip_blue" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <!-- Number + MMS badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+1 (555) 123-4567"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvMmsBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MMS"
                android:textColor="@color/accent_violet"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:background="@drawable/bg_chip_violet"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Message preview -->
        <TextView
            android:id="@+id/tvPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Hello world"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Right: timestamp + status -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14:22"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="sent"
            android:textColor="@color/accent_green"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="5dp"
            android:paddingVertical="1dp" />
    </LinearLayout>

</LinearLayout>
