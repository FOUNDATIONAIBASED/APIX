<?xml version="1.0" encoding="utf-8"?>
<!--
    Android does not support CIDR notation in <domain> entries.
    This agent typically connects to user-controlled gateway URLs (often HTTP on LAN).
    Cleartext is permitted app-wide; use wss:// / https:// server URLs for production.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
