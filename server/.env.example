# ── Server ──────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── Security (change ALL of these before deploying!) ────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_-hex_32
HMAC_SECRET=CHANGE_ME_use_openssl_rand_-hex_32

# Require API key for all write endpoints (recommended: true)
REQUIRE_API_KEY=true

# Number of trusted reverse proxies in front (for correct IPs in rate limits)
# e.g. 1 if behind Nginx/Caddy, 0 for direct
TRUSTED_PROXIES=0

# Set to true when behind HTTPS reverse proxy (domain binding). Leave false/unset for HTTP, LAN, or IP-only access.
# When false (default): use http://IP:port or http://hostname:port — do NOT use https://
# When true: enables upgrade-insecure-requests (browser will prefer HTTPS)
USE_SSL=false

# homelab (default) | production — CORS + API key query policy. Overridden by Settings → deployment_mode after setup.
# In production, set CORS_ORIGINS to a comma-separated list of allowed browser Origins (e.g. https://gateway.example.com).
DEPLOYMENT_MODE=homelab
# CORS_ORIGINS=https://gateway.example.com,https://app.example.com

# Allow one-time admin setup when no users exist. Set to false to disable (e.g. pre-seeded or imported DB).
ALLOW_INITIAL_SETUP=true

# After Settings → Factory reset: by default a detached helper restarts Node (fixes bare `nohup` installs).
# Set to true if systemd/pm2 already restarts the process — avoids a duplicate instance.
# FACTORY_RESET_NO_RESTART=false

# GitHub owner/repo for Settings → Android downloads and GET /api/v1/admin/update-check
# Default in code: FOUNDATIONAIBASED/APIX — https://github.com/FOUNDATIONAIBASED/APIX
# GITHUB_REPO=FOUNDATIONAIBASED/APIX
#
# Version comparison: by default “newest” includes pre-releases (v0.0.3-rc1 can beat v0.0.2).
# Set to true to only consider GitHub “stable” (non-prerelease) releases:
# GITHUB_RELEASES_STABLE_ONLY=false
#
# Cache for GitHub releases fetch (ms), shared by update-check + APK list — default 900000 (15 min)
# GITHUB_VERSION_CACHE_MS=900000

# ── Telegram Forward (optional) ───────────────────────────────────
# Forward inbound SMS/MMS to a Telegram channel. Can also be set in Settings UI.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...   (from @BotFather)
# TELEGRAM_CHAT_ID=-1001234567890        (channel or chat ID)
# TELEGRAM_FORWARD_TO_NUMBER=+15550001111 (optional: only forward messages TO this number)

# ── Session ───────────────────────────────────────────────────────
# Session token TTL in hours (default: 72 hours = 3 days)
SESSION_TTL_HOURS=72

# ── Device Registration ──────────────────────────────────────────
# Auto-approve devices without admin confirmation (NOT recommended in production)
AUTO_APPROVE_DEVICES=false

# ── mDNS (Bonjour — Android auto-discovery) ─────────────────────
MDNS_ENABLED=true
MDNS_NAME=ApiX Gateway

# ── Database ─────────────────────────────────────────────────────
DB_PATH=./data/apix.db

# ── Logging ──────────────────────────────────────────────────────
# Levels: error | warn | info | debug
LOG_LEVEL=info

# ── Rate Limiting ─────────────────────────────────────────────────
# Requests per minute per IP
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_SEND=60

# ── Number Mode ──────────────────────────────────────────────────
# private    = rotate across all pool numbers with random delays (default, recommended for campaigns)
# enterprise = always use one fixed number, no rotation
NUMBER_MODE=private
# Only used when NUMBER_MODE=enterprise:
ENTERPRISE_NUMBER=

# ── SMTP ─────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable emails (unless you configure SMTP in the UI).
# When disabled, password-reset links are printed to the server console instead.
#
# Multi-SMTP (optional): Admins can save many profiles in the web UI
# (Settings → Email / SMTP) with per-window send limits (hourly/daily/weekly/monthly),
# routing (fallback / round-robin / least-used), and quota warning emails.
# When any profile exists in the database, .env SMTP is ignored for sending.
# Max profiles allowed (default 25, max 100):
# SMTP_MAX_PROFILES=25

# Hostname or IP of your mail server
SMTP_HOST=

# Port — common values:
#   25   plain/STARTTLS (usually blocked by ISPs on residential IPs)
#   465  SSL/TLS (SMTP_SECURE=true)
#   587  STARTTLS (SMTP_SECURE=false, recommended for most providers)
#   2525 Alternative STARTTLS (MailGun, SendGrid backup port)
SMTP_PORT=587

# true  = wrap connection in TLS from the start (port 465)
# false = upgrade with STARTTLS after connect (port 587)
SMTP_SECURE=false

# SMTP authentication credentials
SMTP_USER=
SMTP_PASS=

# ── From address ────────────────────────────────────────────────
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=ApiX Gateway

# Reply-to address (optional, defaults to SMTP_FROM if blank)
SMTP_REPLY_TO=

# ── Email branding ───────────────────────────────────────────────
# URL to your logo shown in transactional emails (leave blank for text-only)
EMAIL_LOGO_URL=

# Hex color used for buttons/headers in HTML emails  (#rrggbb)
EMAIL_BRAND_COLOR=#3b82f6

# Optional footer line appended to all outgoing emails
EMAIL_FOOTER=Sent by ApiX Gateway

# ── TLS options ──────────────────────────────────────────────────
# Set to false ONLY for self-signed certs in development — never in production!
SMTP_TLS_REJECT_UNAUTHORIZED=true

# ── Connection pooling (for high-volume transactional email) ─────
# true  = keep a pool of SMTP connections open (faster, uses more resources)
# false = open a new connection per message (default, fine for low volume)
SMTP_POOL=false
# Max simultaneous connections in the pool (only if SMTP_POOL=true)
SMTP_MAX_CONNECTIONS=5
# Max messages per connection before recycling
SMTP_MAX_MESSAGES=100

# ── Common provider quick-start examples ─────────────────────────
# Gmail (App Password required — enable 2FA, then create an App Password):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=you@gmail.com   SMTP_PASS=<app-password>
#
# Outlook / Office 365:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_SECURE=false
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=apikey             SMTP_PASS=<sendgrid-api-key>
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=postmaster@mg.yourdomain.com  SMTP_PASS=<mailgun-smtp-pass>
#
# Brevo (Sendinblue):
#   SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_SECURE=false
#
# Amazon SES (SMTP interface):
#   SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=<ses-iam-access-key-id>  SMTP_PASS=<ses-iam-secret-key>
#
# Self-hosted Postfix/Mailcow (trusted LAN, no TLS):
#   SMTP_HOST=192.168.1.10  SMTP_PORT=25  SMTP_SECURE=false
#   SMTP_TLS_REJECT_UNAUTHORIZED=false
#   SMTP_USER=  SMTP_PASS=   (leave blank if no auth)
#
# Mailtrap (dev/testing — emails never delivered to real inboxes):
#   SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525  SMTP_SECURE=false
#   SMTP_USER=<mailtrap-user>  SMTP_PASS=<mailtrap-pass>
